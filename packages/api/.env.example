# Database
MONGODB_URI=mongodb+srv://...

# JWT
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# Frontend URLs
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
CUSTOMER_URL=http://localhost:3002
FINDER_URL=http://localhost:3003

# Stripe (demo mode if not set)
STRIPE_SECRET_KEY=sk_test_demo_key

# SMTP / Email (demo mode if not set)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# SMS Provider (demo|twilio)
SMS_PROVIDER=demo

# Twilio (only needed if SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Verification Settings (optional, defaults shown)
OTP_EXPIRY_MINUTES=10
EMAIL_TOKEN_EXPIRY_HOURS=24
MAX_OTP_ATTEMPTS=5
MAX_RESEND_COUNT=3
RESEND_COOLDOWN_SECONDS=60
